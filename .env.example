# ─── Application ───────────────────────────────────────────
APP_NAME=Aalam Groups ERP
APP_ENV=development
DEBUG=true

# ─── Backend ───────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
API_V1_PREFIX=/api/v1

# ─── Database ──────────────────────────────────────────────
POSTGRES_USER=aalam
POSTGRES_PASSWORD=aalam_secret
POSTGRES_DB=aalam_erp
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://aalam:aalam_secret@localhost:5432/aalam_erp

# ─── JWT ───────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-to-a-long-random-secret-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── CORS ──────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ─── Frontend ──────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_APP_NAME=Aalam Groups ERP

# ─── Storage ───────────────────────────────────────────────
STORAGE_PATH=./storage/uploads

# ─── Google Maps (future) ──────────────────────────────────
GOOGLE_MAPS_API_KEY=
